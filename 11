        function saveNote() {
            const french = document.getElementById('input-french').value.trim();
            const translation = document.getElementById('input-translation').value.trim();
            const context = document.getElementById('input-context').value.trim();
            const category = document.getElementById('note-category').value;
            
            if (!french) {
                alert(currentLanguage === 'zh' ? '请输入法语内容' : currentLanguage === 'en' ? 'Please enter French content' : 'Veuillez entrer le contenu français');
                return;
            }
            
            // Generate AI-like extensions
            const extensions = generateExtensions(french, category);
            
            const note = {
                id: Date.now(),
                french,
                translation,
                context,
                category,
                tags: [],
                date: new Date().toISOString(),
                extensions
            };
            
            notes.unshift(note);
            saveToStorage();
            renderNotes();
            updateStats();
            
            // Clear inputs
            document.getElementById('input-french').value = '';
            document.getElementById('input-translation').value = '';
            document.getElementById('input-context').value = '';
            
            // Animation feedback
            const btn = document.querySelector('button[onclick="saveNote()"]');
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check mr-2"></i> Saved!';
            btn.classList.add('bg-green-600');
            setTimeout(() => {
                btn.innerHTML = originalHTML;
                btn.classList.remove('bg-green-600');
            }, 1500);
        }

        function generateExtensions(french, category) {
            // Simulated AI generation based on content
            const extensions = {};
            
            if (category === 'vocabulary' || category === 'expression') {
                extensions.example = `Exemple d'utilisation: "${french}..."`;
                extensions.synonym = "Recherche de synonymes en cours...";
                extensions.usage = "Analyse du registre de langue (soutenu/courant/familier)";
            } else if (category === 'grammar') {
                extensions.example = `Application: "${french} est utilisé quand..."`;
                extensions.usage = "Points de vigilance grammaticale";
            } else {
                extensions.example = "Contexte culturel français";
                extensions.usage = "Notes historiques ou culturelles";
            }
            
            return extensions;
        }

        function renderNotes() {
            const container = document.getElementById('notes-container');
            const filtered = currentCategory === 'all' ? notes : notes.filter(n => n.category === currentCategory);
            
            container.innerHTML = filtered.map(note => `
                <div class="note-card glass-panel rounded-xl p-6 cursor-pointer group relative overflow-hidden" onclick="openNote(${note.id})">
                    <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-french-blue/10 to-french-red/10 rounded-bl-full -mr-10 -mt-10 transition-transform group-hover:scale-150"></div>
                    
                    <div class="flex justify-between items-start mb-3">
                        <span class="px-2 py-1 rounded-md text-xs font-medium ${getCategoryColor(note.category)}">
                            ${getCategoryName(note.category)}
                        </span>
                        <span class="text-xs text-gray-400">${formatDate(note.date)}</span>
                    </div>
                    
                    <h3 class="text-xl font-serif font-bold text-gray-800 mb-2 line-clamp-2 group-hover:text-french-blue transition-colors">${note.french}</h3>
                    <p class="text-sm text-gray-600 line-clamp-2 mb-3">${note.translation}</p>
                    
                    <div class="flex items-center justify-between mt-4">
                        <div class="flex space-x-2">
                            ${note.tags.map(tag => `<span class="text-xs px-2 py-1 bg-gray-100 rounded-full text-gray-600">#${tag}</span>`).join('')}
                        </div>
                        <i class="fas fa-chevron-right text-gray-300 group-hover:text-french-blue transition-colors"></i>
                    </div>
                </div>
            `).join('');
            
            // Update counts
            document.getElementById('count-all').textContent = notes.length;
            document.getElementById('count-grammar').textContent = notes.filter(n => n.category === 'grammar').length;
            document.getElementById('count-vocabulary').textContent = notes.filter(n => n.category === 'vocabulary').length;
            document.getElementById('count-culture').textContent = notes.filter(n => n.category === 'culture').length;
        }

        function getCategoryColor(cat) {
            const colors = {
                grammar: 'bg-purple-100 text-purple-700',
                vocabulary: 'bg-blue-100 text-blue-700',
                culture: 'bg-orange-100 text-orange-700',
                expression: 'bg-green-100 text-green-700'
            };
            return colors[cat] || 'bg-gray-100 text-gray-700';
        }

        function getCategoryName(cat) {
            const names = {
                grammar: currentLanguage === 'zh' ? '语法' : currentLanguage === 'en' ? 'Grammar' : 'Grammaire',
                vocabulary: currentLanguage === 'zh' ? '词汇' : currentLanguage === 'en' ? 'Vocabulary' : 'Vocabulaire',
                culture: currentLanguage === 'zh' ? '文化' : currentLanguage === 'en' ? 'Culture' : 'Culture',
                expression: currentLanguage === 'zh' ? '表达' : currentLanguage === 'en' ? 'Expression' : 'Expression'
            };
            return names[cat] || cat;
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString(currentLanguage === 'zh' ? 'zh-CN' : currentLanguage === 'en' ? 'en-US' : 'fr-FR');
        }

        function filterCategory(cat) {
            currentCategory = cat;
            
            // Update UI
            document.querySelectorAll('aside nav button').forEach(btn => {
                btn.classList.remove('bg-french-blue/10', 'text-french-blue');
                btn.classList.add('text-gray-600', 'hover:bg-gray-100');
            });
            event.target.closest('button').classList.remove('text-gray-600', 'hover:bg-gray-100');
            event.target.closest('button').classList.add('bg-french-blue/10', 'text-french-blue');
            
            renderNotes();
        }

        function openNote(id) {
            const note = notes.find(n => n.id === id);
            if (!note) return;
            
            currentNoteId = id;
            document.getElementById('modal-french').textContent = note.french;
            document.getElementById('modal-translation').textContent = note.translation;
            document.getElementById('modal-context').textContent = note.context || 'No context provided';
            document.getElementById('modal-category').textContent = getCategoryName(note.category);
            
            // Render extensions
            const extContainer = document.getElementById('modal-extensions');
            const extLabels = {
                example: i18n[currentLanguage].example,
                synonym: i18n[currentLanguage].synonym,
                antonym: i18n[currentLanguage].antonym,
                usage: i18n[currentLanguage].usage
            };
            
            extContainer.innerHTML = Object.entries(note.extensions || {}).map(([key, value]) => `
                <div class="bg-gradient-to-r from-gray-50 to-white p-4 rounded-xl border border-gray-100">
                    <h5 class="font-bold text-french-blue text-sm mb-1 uppercase tracking-wider">${extLabels[key] || key}</h5>
                    <p class="text-gray-700 text-sm">${value}</p>
                </div>
            `).join('');
            
            document.getElementById('detail-modal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('detail-modal').classList.add('hidden');
            currentNoteId = null;
        }

        function deleteCurrentNote() {
            if (!currentNoteId) return;
            if (confirm(currentLanguage === 'zh' ? '确定删除这条笔记吗？' : 'Delete this note?')) {
                notes = notes.filter(n => n.id !== currentNoteId);
                saveToStorage();
                renderNotes();
                updateStats();
                closeModal();
            }
        }

