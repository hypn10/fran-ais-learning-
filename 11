        // Quiz System
        function startQuiz() {
            if (notes.length < 3) {
                alert(currentLanguage === 'zh' ? '请至少添加3条笔记才能开始测验' : 'Add at least 3 notes to start quiz');
                return;
            }
            
            document.getElementById('start-quiz-btn').classList.add('hidden');
            document.getElementById('quiz-result').classList.add('hidden');
            nextQuestion();
        }

        function nextQuestion() {
            // Select random note
            const note = notes[Math.floor(Math.random() * notes.length)];
            const questionType = Math.random() > 0.5 ? 'translation' : 'context';
            
            let question, answer, options;
            
            if (questionType === 'translation') {
                question = currentLanguage === 'zh' ? `"${note.french}" 是什么意思？` : 
                          currentLanguage === 'en' ? `What does "${note.french}" mean?` :
                          `Que signifie "${note.french}" ?`;
                answer = note.translation;
                
                // Generate wrong options
                const wrongOptions = notes
                    .filter(n => n.id !== note.id)
                    .sort(() => 0.5 - Math.random())
                    .slice(0, 3)
                    .map(n => n.translation);
                
                options = [answer, ...wrongOptions].sort(() => 0.5 - Math.random());
            } else {
                question = currentLanguage === 'zh' ? `以下哪句法语表达了："${note.translation}"？` :
                          currentLanguage === 'en' ? `Which French phrase means: "${note.translation}"?` :
                          `Quelle phrase française signifie : "${note.translation}" ?`;
                answer = note.french;
                
                const wrongOptions = notes
                    .filter(n => n.id !== note.id)
                    .sort(() => 0.5 - Math.random())
                    .slice(0, 3)
                    .map(n => n.french);
                
                options = [answer, ...wrongOptions].sort(() => 0.5 - Math.random());
            }
            
            currentQuiz = { answer, note };
            
            document.getElementById('quiz-question').textContent = question;
            document.getElementById('quiz-hint').textContent = currentLanguage === 'zh' ? '选择正确答案' : 'Select the correct answer';
            
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = options.map((opt, idx) => `
                <button onclick="selectQuizOption('${opt.replace(/'/g, "\\'")}', this)" 
                        class="w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-french-blue hover:bg-blue-50 transition-all text-lg font-medium">
                    ${String.fromCharCode(65 + idx)}. ${opt}
                </button>
            `).join('');
            
            optionsContainer.classList.remove('hidden');
            document.getElementById('quiz-result').classList.add('hidden');
        }

        function selectQuizOption(selected, btnElement) {
            const correct = selected === currentQuiz.answer;
            const buttons = document.querySelectorAll('#quiz-options button');
            
            buttons.forEach(btn => {
                btn.disabled = true;
                if (btn.textContent.includes(currentQuiz.answer)) {
                    btn.classList.add('bg-green-100', 'border-green-500', 'text-green-800');
                } else if (btn === btnElement && !correct) {
                    btn.classList.add('bg-red-100', 'border-red-500', 'text-red-800');
                }
            });
            
            setTimeout(() => {
                document.getElementById('quiz-options').classList.add('hidden');
                const resultDiv = document.getElementById('quiz-result');
                resultDiv.classList.remove('hidden');
                
                if (correct) {
                    resultDiv.querySelector('i').className = 'fas fa-check-circle text-4xl text-green-500 mb-2';
                    resultDiv.querySelector('p').textContent = i18n[currentLanguage].correct;
                    resultDiv.className = 'mt-6 p-6 rounded-xl bg-green-50 border border-green-200 animate-fade-in';
                } else {
                    resultDiv.querySelector('i').className = 'fas fa-times-circle text-4xl text-red-500 mb-2';
                    resultDiv.querySelector('p').textContent = currentLanguage === 'zh' ? '不正确，再试一次' : 'Incorrect, try again';
                    resultDiv.className = 'mt-6 p-6 rounded-xl bg-red-50 border border-red-200 animate-fade-in';
                }
                
                document.getElementById('quiz-explanation').innerHTML = `
                    <strong>${currentQuiz.note.french}</strong><br>
                    ${currentQuiz.note.translation}<br>
                    <span class="text-sm text-gray-500 mt-2 block">${currentQuiz.note.context}</span>
                `;
            }, 500);
        }

