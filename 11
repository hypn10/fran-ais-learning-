        function showConjugation(verb) {
            const display = document.getElementById('conj-display');
            const conjugations = {
                'Parler': ['je parle', 'tu parles', 'il/elle parle', 'nous parlons', 'vous parlez', 'ils/elles parlent'],
                'Finir': ['je finis', 'tu finis', 'il/elle finit', 'nous finissons', 'vous finissez', 'ils/elles finissent'],
                'Vendre': ['je vends', 'tu vends', 'il/elle vend', 'nous vendons', 'vous vendez', 'ils/elles vendent'],
                'Prendre': ['je prends', 'tu prends', 'il/elle prend', 'nous prenons', 'vous prenez', 'ils/elles prennent']
            };
            
            const subjects = ['Je', 'Tu', 'Il/Elle', 'Nous', 'Vous', 'Ils/Elles'];
            
            display.innerHTML = `
                <h4 class="text-xl font-bold mb-4 text-indigo-900">${verb}</h4>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                    ${conjugations[verb].map((form, idx) => `
                        <div class="bg-white/80 p-3 rounded-lg flex justify-between items-center">
                            <span class="font-medium text-indigo-600">${subjects[idx]}</span>
                            <span class="font-serif text-lg">${form.split(' ')[1] || form}</span>
                        </div>
                    `).join('')}
                </div>
            `;
            display.classList.remove('hidden');
        }

        function speak(text) {
            if ('speechSynthesis' in window) {
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'fr-FR';
                utterance.rate = 0.8;
                speechSynthesis.speak(utterance);
            }
        }

        // Data Persistence
        function saveToStorage() {
            localStorage.setItem('frenchNotes', JSON.stringify(notes));
        }

        function updateStats() {
            document.getElementById('total-notes').textContent = notes.length;
        }

        function exportData() {
            const dataStr = JSON.stringify(notes, null, 2);
            const dataBlob = new Blob([dataStr], {type: 'application/json'});
            const url = URL.createObjectURL(dataBlob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `french-notes-${new Date().toISOString().split('T')[0]}.json`;
            link.click();
        }

        function importData(input) {
            const file = input.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const imported = JSON.parse(e.target.result);
                    if (Array.isArray(imported)) {
                        notes = [...imported, ...notes];
                        saveToStorage();
                        renderNotes();
                        updateStats();
                        alert(currentLanguage === 'zh' ? '导入成功！' : 'Import successful!');
                    }
                } catch (err) {
                    alert(currentLanguage === 'zh' ? '文件格式错误' : 'Invalid file format');
                }
            };
            reader.readAsText(file);
            input.value = '';
        }

        function searchNotes() {
            const query = document.getElementById('search-input').value.toLowerCase();
            const cards = document.querySelectorAll('.note-card');
            
            cards.forEach(card => {
                const text = card.innerText.toLowerCase();
                card.style.display = text.includes(query) ? 'block' : 'none';
            });
        }

        function addTag() {
            const tag = prompt(currentLanguage === 'zh' ? '输入标签名:' : 'Enter tag name:');
            if (tag) {
                const container = document.getElementById('tags-container');
                const span = document.createElement('span');
                span.className = 'text-xs px-2 py-1 bg-french-blue/10 text-french-blue rounded-full';
                span.textContent = `#${tag}`;
                container.appendChild(span);
            }
        }

        // Close modal on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });
    </script>
</body>
</html>
