<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PolyGlot 法语学习笔记 | Carnet d'apprentissage</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'serif': ['Playfair Display', 'serif'],
                        'sans': ['Inter', 'Noto Sans SC', 'sans-serif'],
                    },
                    colors: {
                        'french-blue': '#0055A4',
                        'french-red': '#EF4135',
                        'french-gold': '#C5B358',
                        'parchment': '#F9F7F2',
                        'ink': '#2C3E50'
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'fade-in': 'fadeIn 0.5s ease-out',
                        'slide-up': 'slideUp 0.4s ease-out',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        },
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background: linear-gradient(135deg, #F9F7F2 0%, #E8E6E1 100%);
            min-height: 100vh;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        }
        .note-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .note-card:hover {
            transform: translateY(-4px) rotate(1deg);
            box-shadow: 0 20px 40px -5px rgba(0, 0, 0, 0.1);
        }
        .language-btn.active {
            background: linear-gradient(135deg, #0055A4 0%, #003d7a 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(0, 85, 164, 0.3);
        }
        .tab-active {
            border-bottom: 3px solid #0055A4;
            color: #0055A4;
            font-weight: 600;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background-color: rgba(0, 85, 164, 0.3);
            border-radius: 20px;
        }
        .highlight {
            background: linear-gradient(120deg, rgba(197, 179, 88, 0.3) 0%, rgba(197, 179, 88, 0.3) 100%);
            padding: 2px 4px;
            border-radius: 3px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .highlight:hover {
            background: linear-gradient(120deg, rgba(197, 179, 88, 0.6) 0%, rgba(197, 179, 88, 0.6) 100%);
        }
        .morphing-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.4;
        }
        .blob {
            position: absolute;
            filter: blur(80px);
            opacity: 0.6;
            animation: morph 20s ease-in-out infinite;
        }
        @keyframes morph {
            0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
        }
    </style>
</head>
<body class="font-sans text-ink overflow-x-hidden">

    <!-- Animated Background -->
    <div class="morphing-bg">
        <div class="blob bg-blue-200 w-96 h-96 top-0 left-0 animate-float"></div>
        <div class="blob bg-red-200 w-80 h-80 bottom-0 right-0 animate-float" style="animation-delay: -3s;"></div>
        <div class="blob bg-yellow-100 w-72 h-72 top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 animate-float" style="animation-delay: -6s;"></div>
    </div>

    <!-- Header -->
    <header class="glass-panel sticky top-0 z-50 px-6 py-4 mb-8">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-french-blue to-french-red flex items-center justify-center text-white font-serif text-2xl font-bold shadow-lg">
                    P
                </div>
                <div>
                    <h1 class="text-2xl font-serif font-bold text-gray-800 tracking-tight">PolyGlot</h1>
                    <p class="text-xs text-gray-500 font-medium tracking-widest uppercase">French Learning Studio</p>
                </div>
            </div>

            <!-- Language Switcher -->
            <div class="flex space-x-2 bg-white/50 p-1 rounded-full backdrop-blur-sm">
                <button onclick="switchLanguage('zh')" id="btn-zh" class="language-btn active px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-300">
                    中文
                </button>
                <button onclick="switchLanguage('en')" id="btn-en" class="language-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-300 text-gray-600 hover:text-gray-900">
                    English
                </button>
                <button onclick="switchLanguage('fr')" id="btn-fr" class="language-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-300 text-gray-600 hover:text-gray-900">
                    Français
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pb-12 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Left Sidebar: Navigation & Stats -->
        <aside class="lg:col-span-3 space-y-6">
            <!-- Quick Stats -->
            <div class="glass-panel rounded-2xl p-6 animate-fade-in">
                <h3 class="text-lg font-serif font-bold mb-4 flex items-center" data-i18n="stats_title">
                    <i class="fas fa-chart-line mr-2 text-french-blue"></i> 学习统计
                </h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600" data-i18n="notes_count">笔记数量</span>
                        <span class="text-2xl font-bold text-french-blue" id="total-notes">0</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-gradient-to-r from-french-blue to-french-red h-2 rounded-full transition-all duration-1000" style="width: 65%"></div>
                    </div>
                    <div class="flex justify-between text-xs text-gray-500">
                        <span data-i18n="vocabulary">词汇量</span>
                        <span>1,247 mots</span>
                    </div>
                </div>
            </div>

            <!-- Categories -->
            <div class="glass-panel rounded-2xl p-6 animate-fade-in" style="animation-delay: 0.1s">
                <h3 class="text-lg font-serif font-bold mb-4" data-i18n="categories">分类</h3>
                <nav class="space-y-2">
                    <button onclick="filterCategory('all')" class="w-full text-left px-4 py-3 rounded-xl bg-french-blue/10 text-french-blue font-medium transition-all hover:bg-french-blue/20 flex items-center justify-between group">
                        <span><i class="fas fa-layer-group mr-2"></i> <span data-i18n="all_notes">全部笔记</span></span>
                        <span class="bg-white/50 px-2 py-0.5 rounded-full text-xs" id="count-all">0</span>
                    </button>
                    <button onclick="filterCategory('grammar')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-gray-100 transition-all flex items-center justify-between group text-gray-600">
                        <span><i class="fas fa-book mr-2"></i> <span data-i18n="grammar">语法</span></span>
                        <span class="bg-gray-100 px-2 py-0.5 rounded-full text-xs" id="count-grammar">0</span>
                    </button>
                    <button onclick="filterCategory('vocabulary')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-gray-100 transition-all flex items-center justify-between group text-gray-600">
                        <span><i class="fas fa-language mr-2"></i> <span data-i18n="vocabulary_cat">词汇</span></span>
                        <span class="bg-gray-100 px-2 py-0.5 rounded-full text-xs" id="count-vocabulary">0</span>
                    </button>
                    <button onclick="filterCategory('culture')" class="w-full text-left px-4 py-3 rounded-xl hover:bg-gray-100 transition-all flex items-center justify-between group text-gray-600">
                        <span><i class="fas fa-wine-glass mr-2"></i> <span data-i18n="culture">文化</span></span>
                        <span class="bg-gray-100 px-2 py-0.5 rounded-full text-xs" id="count-culture">0</span>
                    </button>
                </nav>
            </div>

            <!-- Export/Import -->
            <div class="glass-panel rounded-2xl p-6 animate-fade-in" style="animation-delay: 0.2s">
                <h3 class="text-lg font-serif font-bold mb-4" data-i18n="data_management">数据管理</h3>
                <div class="space-y-2">
                    <button onclick="exportData()" class="w-full py-2 px-4 rounded-lg border border-french-blue text-french-blue hover:bg-french-blue hover:text-white transition-all text-sm font-medium">
                        <i class="fas fa-download mr-2"></i> <span data-i18n="export">导出存档</span>
                    </button>
                    <label class="w-full py-2 px-4 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 transition-all text-sm font-medium cursor-pointer block text-center">
                        <i class="fas fa-upload mr-2"></i> <span data-i18n="import">导入数据</span>
                        <input type="file" id="import-file" class="hidden" accept=".json" onchange="importData(this)">
                    </label>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <section class="lg:col-span-9 space-y-6">
            
            <!-- Input Area -->
            <div class="glass-panel rounded-2xl p-8 animate-slide-up shadow-xl">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-2xl font-serif font-bold text-gray-800" data-i18n="new_note">新建学习笔记</h2>
                    <div class="flex space-x-2">
                        <select id="note-category" class="px-4 py-2 rounded-lg border border-gray-200 bg-white/50 text-sm focus:outline-none focus:ring-2 focus:ring-french-blue">
                            <option value="grammar" data-i18n="grammar">语法</option>
                            <option value="vocabulary" data-i18n="vocabulary_cat">词汇</option>
                            <option value="culture" data-i18n="culture">文化</option>
                            <option value="expression" data-i18n="expression">表达</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-2" data-i18n="french_content">法语内容</label>
                            <textarea id="input-french" rows="3" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white/80 focus:bg-white focus:ring-2 focus:ring-french-blue focus:border-transparent transition-all resize-none font-serif text-lg" placeholder="Entrez votre texte en français..."></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-2" data-i18n="translation">翻译 / Translation</label>
                            <textarea id="input-translation" rows="3" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white/80 focus:bg-white focus:ring-2 focus:ring-french-blue focus:border-transparent transition-all resize-none" placeholder="中文或英文翻译..."></textarea>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-2" data-i18n="notes_context">语境 / 注释</label>
                        <textarea id="input-context" rows="2" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white/80 focus:bg-white focus:ring-2 focus:ring-french-blue focus:border-transparent transition-all resize-none" placeholder="添加使用场景、语法说明或文化背景..."></textarea>
                    </div>

                    <div class="flex justify-between items-center pt-2">
                        <div class="flex space-x-2">
                            <button onclick="addTag()" class="px-3 py-1.5 rounded-lg bg-gray-100 text-gray-600 text-sm hover:bg-gray-200 transition-colors">
                                <i class="fas fa-tag mr-1"></i> <span data-i18n="add_tag">添加标签</span>
                            </button>
                            <div id="tags-container" class="flex space-x-2"></div>
                        </div>
                        <button onclick="saveNote()" class="px-8 py-3 bg-gradient-to-r from-french-blue to-blue-600 text-white rounded-xl font-medium shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all flex items-center">
                            <i class="fas fa-save mr-2"></i> <span data-i18n="save">保存笔记</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <div class="flex space-x-8 border-b border-gray-200 px-2">
                <button onclick="switchTab('library')" id="tab-library" class="tab-active pb-3 text-sm font-medium transition-colors" data-i18n="library">资料库</button>
                <button onclick="switchTab('review')" id="tab-review" class="pb-3 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" data-i18n="review_mode">提问复习</button>
                <button onclick="switchTab('extension')" id="tab-extension" class="pb-3 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" data-i18n="extensions">延伸学习</button>
            </div>

            <!-- Content Views -->
            <div id="view-library" class="space-y-4">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-serif font-bold" data-i18n="recent_notes">最近笔记</h3>
                    <div class="relative">
                        <input type="text" id="search-input" onkeyup="searchNotes()" class="pl-10 pr-4 py-2 rounded-full border border-gray-200 bg-white/50 focus:bg-white focus:ring-2 focus:ring-french-blue text-sm w-64 transition-all" placeholder="Rechercher...">
                        <i class="fas fa-search absolute left-3 top-2.5 text-gray-400"></i>
                    </div>
                </div>
                
                <div id="notes-container" class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-[600px] overflow-y-auto custom-scrollbar pr-2">
                    <!-- Notes will be injected here -->
                </div>
            </div>

            <!-- Review Mode -->
            <div id="view-review" class="hidden space-y-6">
                <div class="glass-panel rounded-2xl p-8 text-center min-h-[400px] flex flex-col justify-center items-center">
                    <div id="quiz-container" class="w-full max-w-2xl">
                        <div class="mb-8">
                            <span class="inline-block px-4 py-1 rounded-full bg-french-blue/10 text-french-blue text-sm font-medium mb-4" data-i18n="question_mode">提问模式</span>
                            <h3 class="text-2xl font-serif font-bold mb-2" id="quiz-question" data-i18n="start_quiz">准备好挑战了吗？</h3>
                            <p class="text-gray-600" id="quiz-hint" data-i18n="quiz_hint">系统将基于你的笔记生成问题</p>
                        </div>
                        
                        <div id="quiz-options" class="space-y-3 hidden">
                            <!-- Options injected here -->
                        </div>

                        <div id="quiz-input-area" class="hidden space-y-4">
                            <input type="text" id="quiz-answer-input" class="w-full px-6 py-4 text-center text-xl border-2 border-gray-200 rounded-xl focus:border-french-blue focus:ring-0 font-serif" placeholder="Votre réponse...">
                            <button onclick="checkAnswer()" class="w-full py-3 bg-french-blue text-white rounded-xl font-medium hover:bg-blue-700 transition-colors" data-i18n="confirm">确认</button>
                        </div>

                        <button onclick="startQuiz()" id="start-quiz-btn" class="px-8 py-4 bg-gradient-to-r from-french-red to-red-600 text-white rounded-xl font-bold text-lg shadow-lg hover:shadow-xl transform hover:scale-105 transition-all">
                            <i class="fas fa-play mr-2"></i> <span data-i18n="start">开始挑战</span>
                        </button>

                        <div id="quiz-result" class="hidden mt-6 p-6 rounded-xl bg-green-50 border border-green-200 animate-fade-in">
                            <i class="fas fa-check-circle text-4xl text-green-500 mb-2"></i>
                            <p class="text-lg font-medium text-green-800" data-i18n="correct">正确！</p>
                            <p class="text-green-600 mt-2" id="quiz-explanation"></p>
                            <button onclick="nextQuestion()" class="mt-4 px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors" data-i18n="next">下一题</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Extensions View -->
            <div id="view-extension" class="hidden space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="glass-panel rounded-2xl p-6 hover:shadow-lg transition-all cursor-pointer group" onclick="loadExtension('conjugation')">
                        <div class="w-12 h-12 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fas fa-random text-xl"></i>
                        </div>
                        <h4 class="font-bold text-lg mb-2" data-i18n="verb_conj">动词变位</h4>
                        <p class="text-sm text-gray-600" data-i18n="conj_desc">练习常用动词的不同时态变位</p>
                    </div>
                    
                    <div class="glass-panel rounded-2xl p-6 hover:shadow-lg transition-all cursor-pointer group" onclick="loadExtension('phrases')">
                        <div class="w-12 h-12 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fas fa-comments text-xl"></i>
                        </div>
                        <h4 class="font-bold text-lg mb-2" data-i18n="daily_phrases">日常用语</h4>
                        <p class="text-sm text-gray-600" data-i18n="phrases_desc">高频场景对话与表达</p>
                    </div>

                    <div class="glass-panel rounded-2xl p-6 hover:shadow-lg transition-all cursor-pointer group" onclick="loadExtension('phonetics')">
                        <div class="w-12 h-12 rounded-full bg-teal-100 text-teal-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                            <i class="fas fa-microphone text-xl"></i>
                        </div>
                        <h4 class="font-bold text-lg mb-2" data-i18n="phonetics">语音练习</h4>
                        <p class="text-sm text-gray-600" data-i18n="phonetics_desc">鼻化元音与连诵规则</p>
                    </div>
                </div>

                <div id="extension-content" class="glass-panel rounded-2xl p-8 min-h-[300px]">
                    <div class="text-center text-gray-400 py-12">
                        <i class="fas fa-hand-pointer text-4xl mb-4 opacity-50"></i>
                        <p data-i18n="select_extension">选择一个模块开始学习</p>
                    </div>
                </div>
            </div>

        </section>
    </main>

    <!-- Detail Modal -->
    <div id="detail-modal" class="fixed inset-0 z-[60] hidden">
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeModal()"></div>
        <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
            <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-y-auto pointer-events-auto animate-slide-up">
                <div class="p-8">
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <span id="modal-category" class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mb-2 inline-block">Category</span>
                            <h2 id="modal-french" class="text-3xl font-serif font-bold text-gray-800 mb-2"></h2>
                            <p id="modal-translation" class="text-lg text-gray-600 italic"></p>
                        </div>
                        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                            <i class="fas fa-times text-2xl"></i>
                        </button>
                    </div>
                    
                    <div class="prose max-w-none mb-6">
                        <h4 class="font-bold text-gray-800 mb-2 flex items-center">
                            <i class="fas fa-align-left mr-2 text-french-blue"></i> 
                            <span data-i18n="context">语境说明</span>
                        </h4>
                        <p id="modal-context" class="text-gray-600 leading-relaxed bg-gray-50 p-4 rounded-xl"></p>
                    </div>

                    <div class="border-t pt-6">
                        <h4 class="font-bold text-gray-800 mb-4 flex items-center">
                            <i class="fas fa-lightbulb mr-2 text-french-gold"></i>
                            <span data-i18n="ai_extensions">AI 延伸学习</span>
                        </h4>
                        <div id="modal-extensions" class="space-y-3">
                            <!-- Dynamic extensions -->
                        </div>
                    </div>

                    <div class="flex justify-end space-x-3 mt-8 pt-4 border-t">
                        <button onclick="deleteCurrentNote()" class="px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" data-i18n="delete">删除</button>
                        <button onclick="closeModal()" class="px-6 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors" data-i18n="close">关闭</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Data Store
        let notes = JSON.parse(localStorage.getItem('frenchNotes')) || [];
        let currentLanguage = 'zh';
        let currentCategory = 'all';
        let currentNoteId = null;
        let currentQuiz = null;

        // Translations
        const i18n = {
            zh: {
                stats_title: '学习统计',
                notes_count: '笔记数量',
                vocabulary: '词汇量',
                categories: '分类',
                all_notes: '全部笔记',
                grammar: '语法',
                vocabulary_cat: '词汇',
                culture: '文化',
                expression: '表达',
                data_management: '数据管理',
                export: '导出存档',
                import: '导入数据',
                new_note: '新建学习笔记',
                french_content: '法语内容',
                translation: '翻译 / Translation',
                notes_context: '语境 / 注释',
                add_tag: '添加标签',
                save: '保存笔记',
                library: '资料库',
                review_mode: '提问复习',
                extensions: '延伸学习',
                recent_notes: '最近笔记',
                question_mode: '提问模式',
                start_quiz: '准备好挑战了吗？',
                quiz_hint: '系统将基于你的笔记生成问题',
                start: '开始挑战',
                confirm: '确认',
                correct: '正确！',
